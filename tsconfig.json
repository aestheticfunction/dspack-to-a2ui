{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "declaration": true,
    "outDir": "dist"
  },
  "include": ["src"],
  "comment": "Test files are run + type-stripped by vitest/esbuild and may import the demo's React adapter; tsc here validates only the shippable transformer.",
  "exclude": ["node_modules", "demo", "dist", "src/**/*.test.ts"]
}
